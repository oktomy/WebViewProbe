<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WebView 診斷探針"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="輸入測試網址 (含 https://)"
                android:inputType="textUri" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="次數(例:100)"
                    android:inputType="number" />

                <EditText
                    android:id="@+id/etDelay"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="間隔毫秒(例:2000)"
                    android:inputType="number" />
            </LinearLayout>

            <CheckBox
                android:id="@+id/cbUa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="偽裝原生 Chrome Browser UA" />

            <CheckBox
                android:id="@+id/cbDom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="開啟 DOM Storage (前端必備)"
                android:checked="true" />

            <CheckBox
                android:id="@+id/cbCache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="每次重載前清除 Cache 與 Cookie" />

            <Button
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="開始測試"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="進度: 0 / 0"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="延遲(ms) - 最小:0 | 最大:0 | 平均:0" />

            <TextView
                android:id="@+id/tvErrors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="異常 - HTTP:0 | OOM:0 | Timeout:0"
                android:textColor="#D32F2F"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvAnalysis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="報告生成中..."
                android:textColor="#0277BD"
                android:background="#E1F5FE"
                android:padding="12dp"
                android:visibility="gone"/>
        </LinearLayout>
    </ScrollView>

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#EEEEEE"
        android:layout_marginTop="4dp"/>

</LinearLayout>
